{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ChessmateCloudWatchAlarms",
      "Effect": "Allow",
      "Action": [
        "cloudwatch:PutMetricAlarm",
        "cloudwatch:DeleteAlarms",
        "cloudwatch:DescribeAlarms",
        "cloudwatch:SetAlarmState",
        "cloudwatch:TagResource",
        "cloudwatch:UntagResource"
      ],
      "Resource": "arn:aws:cloudwatch:us-east-2:381492194867:alarm:Chessmate-*"
    },
    {
      "Sid": "ChessmateSnsCreateTopic",
      "Effect": "Allow",
      "Action": [
        "sns:CreateTopic",
        "sns:ListTopics"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ChessmateSnsAlarmsTopicManage",
      "Effect": "Allow",
      "Action": [
        "sns:Subscribe",
        "sns:ListSubscriptionsByTopic",
        "sns:GetTopicAttributes",
        "sns:SetTopicAttributes"
      ],
      "Resource": "arn:aws:sns:us-east-2:381492194867:chessmate-prod-alarms"
    }
  ]
}
