# Django Settings
ENVIRONMENT=development
DEBUG=False
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=your-domain.com,localhost,127.0.0.1
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Database Settings
DB_NAME=chessmate
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your_db_host
DB_PORT=5432

# Redis Settings
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email Settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Stripe Settings
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-public-key
PAYMENT_SUCCESS_URL=http://your-domain.com/payment/success
PAYMENT_CANCEL_URL=http://your-domain.com/payment/cancel

# OpenAI Settings
OPENAI_API_KEY=your-openai-api-key

# AWS Settings
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_BACKUP_BUCKET=your-bucket-name
AWS_REGION=us-east-2

# Frontend / API Settings
REACT_APP_API_URL=http://localhost:8000
DJANGO_SETTINGS_MODULE=chess_mate.settings

# Optional local development toggles
REDIS_DISABLED=True
ENABLE_CELERY=true

# Stockfish Settings
STOCKFISH_PATH=/usr/games/stockfish
