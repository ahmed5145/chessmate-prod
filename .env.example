# Copy to .env in the repo root:  cp .env.example .env
# Never commit .env (secrets).

# --- Django ---
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=change-me-use-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=chess_mate.settings

# --- Database (local: docker-compose db service) ---
DB_NAME=chessmate
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# --- Redis (local: docker-compose redis service, or redis-server on 6379) ---
# Use REDIS_DISABLED=True only if you are not running Redis and accept in-memory cache (no Celery).
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DISABLED=False
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
ENABLE_CELERY=true

# --- Frontend (Create React App; only for npm start / local build) ---
# Full origin, no trailing /api — paths in code already use /api/v1/...
REACT_APP_API_URL=http://localhost:8000

# --- Production on Elastic Beanstalk (set in AWS console, not in this file) ---
# REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# USE_BUNDLED_REDIS=true
# ENABLE_CELERY=true
# Do NOT set REACT_APP_API_URL on CD/EB (causes /api/api/v1/...)

# --- Email (optional) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# --- Stripe (optional; required for confirm_stripe_payment from your PC) ---
# Copy sk_test_... from Stripe Dashboard → Developers → API keys (same as EB).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
PAYMENT_SUCCESS_URL=http://localhost:3000/payment/success
PAYMENT_CANCEL_URL=http://localhost:3000/payment/cancel

# --- OpenAI (batch coaching) ---
OPENAI_API_KEY=

# --- AWS (deploy / backups) ---
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BACKUP_BUCKET=
AWS_REGION=us-east-2

# --- Stockfish ---
STOCKFISH_PATH=/usr/games/stockfish
